# Environment variables for PUBG Team Finder
# Copy this file to .env and fill in the values

# Discord OAuth2
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# Discord Bot (for creating voice channels)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Security
SECRET_KEY=your_secret_key_32_chars_minimum_here
# Generate with: openssl rand -hex 32

# Database
DATABASE_URL=postgresql+async://pubg_finder:pubg_finder_secret@postgres:5432/pubg_finder

# Redis
REDIS_URL=redis://redis:6379

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DISCORD_CLIENT_ID=your_discord_client_id_here
NEXT_PUBLIC_DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/callback
